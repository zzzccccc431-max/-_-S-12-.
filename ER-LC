_G.HeadSize = 20;
_G.Disabled = true;
_G.TeamCheck = false;
local RunService = game:GetService("RunService");
local Players = game:GetService("Players");
local LocalPlayer = Players.LocalPlayer;
local UIS = game:GetService("UserInputService");
local Camera = workspace.CurrentCamera;
local OriginalHeads = {};
local healthGuis = {};
local BOX_SIZE = Vector2.new(80, 120);
local Boxes = {};
local Lines = {};
local function removeESP(player)
	if Boxes[player] then
		Boxes[player]:Remove();
		Boxes[player] = nil;
	end
	if Lines[player] then
		Lines[player]:Remove();
		Lines[player] = nil;
	end
end
Players.PlayerRemoving:Connect(function(player)
	removeESP(player);
	if healthGuis[player] then
		healthGuis[player]:Destroy();
		healthGuis[player] = nil;
	end
end);
local function createHealthGui(plr, char)
	if healthGuis[plr] then
		healthGuis[plr]:Destroy();
	end
	local head = char:FindFirstChild("Head");
	if not head then
		return;
	end
	local gui = Instance.new("BillboardGui");
	gui.Size = UDim2.new(0, 120, 0, 30);
	gui.StudsOffset = Vector3.new(0, 2.5, 0);
	gui.AlwaysOnTop = true;
	gui.MaxDistance = 200;
	gui.Enabled = _G.Disabled;
	local text = Instance.new("TextLabel");
	text.Size = UDim2.new(1, 0, 1, 0);
	text.BackgroundTransparency = 1;
	text.TextColor3 = Color3.fromRGB(255, 0, 0);
	text.TextStrokeTransparency = 0;
	text.TextSize = 14;
	text.Font = Enum.Font.SourceSansBold;
	text.Parent = gui;
	gui.Parent = head;
	healthGuis[plr] = gui;
end
local function setupPlayer(plr)
	if (plr == LocalPlayer) then
		return;
	end
	local function onCharacter(char)
		removeESP(plr);
		local humanoid = char:FindFirstChild("Humanoid");
		local head = char:FindFirstChild("Head");
		local root = char:FindFirstChild("HumanoidRootPart");
		if not (humanoid and head and root) then
			return;
		end
		createHealthGui(plr, char);
	end
	plr.CharacterAdded:Connect(function(char)
		if _G.Disabled then
			task.wait(0.1);
			onCharacter(char);
		end
	end);
	if plr.Character then
		onCharacter(plr.Character);
	end
end
for _, plr in pairs(Players:GetPlayers()) do
	setupPlayer(plr);
end
Players.PlayerAdded:Connect(function(plr)
	setupPlayer(plr);
	if (_G.Disabled and plr.Character) then
		createHealthGui(plr, plr.Character);
	end
end);
UIS.InputBegan:Connect(function(input)
	if (input.KeyCode == Enum.KeyCode.X) then
		_G.Disabled = not _G.Disabled;
		for _, gui in pairs(healthGuis) do
			gui.Enabled = _G.Disabled;
		end
		if not _G.Disabled then
			for _, v in pairs(Players:GetPlayers()) do
				if (v ~= LocalPlayer) then
					local char = v.Character;
					if char then
						local head = char:FindFirstChild("Head");
						if (head and OriginalHeads[v]) then
							head.Size = OriginalHeads[v];
							head.Transparency = 0;
							head.CanCollide = true;
							head.Massless = false;
						end
					end
					removeESP(v);
					if healthGuis[v] then
						healthGuis[v].Enabled = false;
					end
				end
			end
		end
	end
	if (input.KeyCode == Enum.KeyCode.Z) then
		_G.TeamCheck = not _G.TeamCheck;
		for _, v in pairs(Players:GetPlayers()) do
			if (v ~= LocalPlayer) then
				local char = v.Character;
				if char then
					local head = char:FindFirstChild("Head");
					if (head and OriginalHeads[v]) then
						if (_G.TeamCheck and (v.Team == LocalPlayer.Team)) then
							head.Size = OriginalHeads[v];
							head.Transparency = 0;
							head.CanCollide = true;
							head.Massless = false;
						end
					end
				end
			end
		end
	end
end);
RunService.RenderStepped:Connect(function()
	if not _G.Disabled then
		return;
	end
	for _, v in pairs(Players:GetPlayers()) do
		if (v == LocalPlayer) then
			continue;
		end
		local char = v.Character;
		if not char then
			removeESP(v);
			continue;
		end
		local humanoid = char:FindFirstChild("Humanoid");
		local head = char:FindFirstChild("Head");
		local root = char:FindFirstChild("HumanoidRootPart");
		if (not humanoid or (humanoid.Health <= 0) or not head or not root) then
			removeESP(v);
			continue;
		end
		if (_G.TeamCheck and (v.Team == LocalPlayer.Team)) then
			removeESP(v);
			if healthGuis[v] then
				healthGuis[v].Enabled = false;
			end
			continue;
		end
		if not OriginalHeads[v] then
			OriginalHeads[v] = head.Size;
		end
		head.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize);
		head.Transparency = 1;
		head.CanCollide = false;
		head.Massless = true;
		if healthGuis[v] then
			healthGuis[v].Enabled = true;
			local text = healthGuis[v]:FindFirstChildOfClass("TextLabel");
			if text then
				text.Text = math.floor(humanoid.Health) .. " HP";
			end
		end
		if not Boxes[v] then
			local box = Drawing.new("Square");
			box.Color = Color3.new(1, 0, 0);
			box.Thickness = 2;
			box.Filled = false;
			Boxes[v] = box;
		end
		if not Lines[v] then
			local line = Drawing.new("Line");
			line.Color = Color3.new(1, 0, 0);
			line.Thickness = 1.5;
			Lines[v] = line;
		end
		local pos, onScreen = Camera:WorldToViewportPoint(root.Position);
		if onScreen then
			Boxes[v].Size = BOX_SIZE;
			Boxes[v].Position = Vector2.new(pos.X - 40, pos.Y - 60);
			Boxes[v].Visible = true;
			Lines[v].From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y);
			Lines[v].To = Vector2.new(pos.X, pos.Y);
			Lines[v].Visible = true;
		else
			Boxes[v].Visible = false;
			Lines[v].Visible = false;
		end
	end
end);
